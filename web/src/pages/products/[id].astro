---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((p) => ({ params: { id: p.id }, props: { product: p } }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const d = product.data;

const waText = `Hi MAADHURAM, I'd like to order: ${d.title}.`;
const waHref = `https://wa.me/919652924824?text=${encodeURIComponent(waText)}`;
---

<BaseLayout
  title={`${d.title} — MAADHURAM`}
  description={d.blurb}
  active="products"
>
  <section class="py-12 md:py-16">
    <div class="container-page">
      <a href="/products/" class="inline-block text-sm text-[var(--color-sage-700)] hover:underline mb-6">
        ← Back to all products
      </a>

      <div class="grid md:grid-cols-2 gap-10 lg:gap-14 items-start">
        <div class="bg-[var(--color-cream-dark)] rounded-2xl overflow-hidden aspect-[4/5] shadow-[var(--shadow-soft)]">
          <img src={d.image} alt={d.title} class="w-full h-full object-cover" />
        </div>

        <div>
          {d.badge && (
            <span class="inline-block text-[0.65rem] tracking-[0.18em] uppercase text-[var(--color-sage-700)] bg-[var(--color-sage-200)] px-2.5 py-0.5 rounded-full mb-3">
              {d.badge}
            </span>
          )}
          <h1 class="text-4xl md:text-5xl mb-2">{d.title}</h1>
          <p class="text-lg italic text-[var(--color-sage-700)] mb-5">{d.tagline}</p>

          {d.size && (
            <div class="text-[var(--color-muted)] mb-6">{d.size}</div>
          )}

          <p class="text-[var(--color-ink)] mb-6">{d.blurb}</p>

          <div class="flex flex-wrap gap-3 mb-8">
            <a class="btn btn-whatsapp" href={waHref} target="_blank" rel="noopener">
              Order on WhatsApp
            </a>
            <a class="btn btn-ghost" href="/contact/">Ask a question</a>
          </div>

          {d.benefits.length > 0 && (
            <div class="mb-6">
              <div class="eyebrow mb-3">What it does</div>
              <ul class="grid gap-1.5 list-none p-0 m-0">
                {d.benefits.map((b) => (
                  <li class="flex items-start gap-2 text-[var(--color-ink)]">
                    <span class="text-[var(--color-sage-600)] mt-1">·</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {d.ingredients.length > 0 && (
            <div>
              <div class="eyebrow mb-3">Ingredients</div>
              <div class="flex flex-wrap gap-2">
                {d.ingredients.map((i) => (
                  <span class="inline-block text-sm bg-[var(--color-sage-100)] text-[var(--color-sage-900)] px-3 py-1 rounded-full">
                    {i}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

      {d.variants.length > 0 && (
        <section class="mt-16">
          <div class="eyebrow mb-2">Varieties</div>
          <h2 class="text-3xl mb-2">Choose your soap.</h2>
          <p class="text-[var(--color-muted)] max-w-xl mb-8">
            Four small-batch varieties, each built around a single hero ingredient.
            Mention your picks when you message us on WhatsApp.
          </p>

          <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-4">
            {d.variants.map((v) => (
              <div class="bg-white border border-[var(--color-line)] rounded-xl overflow-hidden shadow-[var(--shadow-soft)] flex flex-col">
                <div class="aspect-square bg-[var(--color-cream-dark)] overflow-hidden">
                  <img src={v.image} alt={`${v.name} soap`} loading="lazy" class="w-full h-full object-cover" />
                </div>
                <div class="p-4 pb-5 flex flex-col gap-1 flex-1">
                  <h3 class="font-display text-lg text-[var(--color-sage-900)] m-0">{v.name}</h3>
                  {v.note && <p class="text-[var(--color-muted)] text-sm m-0">{v.note}</p>}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <article class="prose mt-14 max-w-2xl text-[var(--color-ink)] leading-relaxed">
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>
