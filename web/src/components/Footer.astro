---
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-sage-900)] text-[#d9d6c9] mt-20 pt-14 pb-7">
  <div class="container-page grid gap-10 md:grid-cols-[1.3fr_1fr_1fr] mb-8">
    <div>
      <a href="/" class="flex items-center gap-3">
        <img src="/logo.jpg" alt="MAADHURAM" class="w-10 h-10 rounded-full object-cover" />
        <span class="font-display text-[1.15rem] font-semibold tracking-[0.14em] text-[var(--color-cream)]">
          MAADHURAM
        </span>
      </a>
      <p class="mt-3 max-w-sm text-[#c7c4b8]">
        Handcrafted herbal care, rooted in tradition. Small batch. Honest formulas.
      </p>
    </div>

    <div>
      <h4 class="font-display text-base tracking-[0.12em] uppercase text-[var(--color-cream)] mb-3">Explore</h4>
      <ul class="list-none p-0 m-0 grid gap-2">
        <li><a class="text-[var(--color-cream)] hover:underline" href="/">Home</a></li>
        <li><a class="text-[var(--color-cream)] hover:underline" href="/products/">Products</a></li>
        <li><a class="text-[var(--color-cream)] hover:underline" href="/about/">About</a></li>
        <li><a class="text-[var(--color-cream)] hover:underline" href="/contact/">Contact</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-display text-base tracking-[0.12em] uppercase text-[var(--color-cream)] mb-3">Reach Us</h4>
      <ul class="list-none p-0 m-0 grid gap-2">
        <li><a class="text-[var(--color-cream)] hover:underline" href="mailto:maadhuram.handmade@gmail.com">maadhuram.handmade@gmail.com</a></li>
        <li><a class="text-[var(--color-cream)] hover:underline" href="https://wa.me/919652924824">WhatsApp · +91 96529 24824</a></li>
        <li><a class="text-[var(--color-cream)] hover:underline" href="https://www.instagram.com/maadhuram.handmade/" target="_blank" rel="noopener">Instagram · @maadhuram.handmade</a></li>
      </ul>
    </div>
  </div>

  <div class="container-page border-t border-white/10 pt-5 flex flex-wrap justify-between gap-3 text-sm text-[#b1ae9f]">
    <div>© {year} MAADHURAM. All rights reserved.</div>
    <div>Made with care in India.</div>
  </div>
</footer>
