---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import ChatWidget from "../components/ChatWidget.astro";

const products = (await getCollection("products")).sort(
  (a, b) => a.data.order - b.data.order,
);

const values = [
  { icon: "🌿", title: "Plant-Based", body: "Sourced from nature, not labs. Every ingredient earns its place." },
  { icon: "🫙", title: "Small Batch", body: "Handmade in careful quantities to protect freshness and quality." },
  { icon: "🪔", title: "Rooted in Tradition", body: "Recipes drawn from Indian household wisdom, refined for today." },
  { icon: "💧", title: "Clean Formulas", body: "Free from parabens, SLS, and synthetic fragrances. Always." },
];

const soaps = [
  { name: "Papaya",   image: "/products/soap-papaya.png",   note: "Brightening enzymes." },
  { name: "Beetroot", image: "/products/soap-beetroot.png", note: "Natural radiance." },
  { name: "Lavender", image: "/products/soap-lavender.png", note: "Calm, balancing." },
  { name: "Ubtan",    image: "/products/soap-ubtan.png",    note: "Traditional glow." },
];
---

<BaseLayout title="MAADHURAM — Meet Your Natural Side" active="home">
  <section class="relative py-24 md:py-32 bg-[var(--color-sage-900)]">
    <div class="container-page max-w-3xl text-center">
      <h1 class="text-[clamp(2rem,4.5vw,3.6rem)] mb-3 text-[var(--color-cream)]">Nature, bottled with care.</h1>
      <p class="text-lg md:text-xl italic text-[#d9d6c9] mb-7">
        Traditional recipes. Clean ingredients. A gentler way to care for your body.
      </p>
      <div class="flex gap-3 justify-center flex-wrap">
        <a class="btn bg-[var(--color-cream)] text-[var(--color-sage-900)] hover:bg-white hover:-translate-y-px" href="/products/">Shop Products</a>
        <a class="btn border-[var(--color-cream)] text-[var(--color-cream)] hover:bg-[var(--color-cream)] hover:text-[var(--color-sage-900)]" href="/about/">Our Story</a>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <div class="eyebrow mb-2">Featured</div>
        <h2 class="text-3xl md:text-4xl mb-3">Our everyday essentials</h2>
        <p class="text-[var(--color-muted)]">
          Made in small batches, blending time-honored herbs with modern care standards.
        </p>
      </div>

      <div class="grid gap-7 sm:grid-cols-2 max-w-3xl mx-auto">
        {products.map((p) => (
          <ProductCard
            href={`/products/${p.id}/`}
            title={p.data.title}
            blurb={p.data.tagline}
            image={p.data.image}
            badge={p.data.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-cream-dark)] py-16">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <div class="eyebrow mb-2">Soap Varieties</div>
        <h2 class="text-3xl md:text-4xl mb-3">Four bars. Four hero ingredients.</h2>
        <p class="text-[var(--color-muted)]">
          Pick one, or mix and match — let us know your favourites when you message us.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {soaps.map((s) => (
          <a
            href="/products/handmade-soaps/"
            class="group bg-white border border-[var(--color-line)] rounded-xl overflow-hidden shadow-[var(--shadow-soft)] hover:shadow-[var(--shadow-lift)] hover:-translate-y-1 transition-all duration-200 flex flex-col"
          >
            <div class="aspect-square bg-[var(--color-cream-dark)] overflow-hidden">
              <img
                src={s.image}
                alt={`${s.name} soap`}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-4 pb-5 flex flex-col gap-1 flex-1">
              <h3 class="font-display text-lg text-[var(--color-sage-900)] m-0">{s.name}</h3>
              <p class="text-[var(--color-muted)] text-sm m-0">{s.note}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-sage-900)] text-[var(--color-cream)] py-16">
    <div class="container-page">
      <h2 class="text-3xl md:text-4xl text-center text-[var(--color-cream)] mb-10">What we stand for</h2>
      <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-4 text-center">
        {values.map((v) => (
          <div class="px-2">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full grid place-items-center bg-white/10 text-xl">
              {v.icon}
            </div>
            <h3 class="text-[var(--color-cream)] text-lg mb-1">{v.title}</h3>
            <p class="text-[#d9d6c9] text-sm m-0">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container-page grid md:grid-cols-2 gap-12 items-center">
      <div>
        <div class="eyebrow mb-2">Our Story</div>
        <h2 class="text-3xl md:text-4xl mb-4">From our kitchen to your care routine.</h2>
        <p class="text-[var(--color-muted)] mb-4">
          MAADHURAM began with a simple idea: the most effective care often comes from
          what grows closest to us. We blend heirloom herbal recipes with modern, honest
          practices — so every bottle and bar carries real intention.
        </p>
        <p class="text-[var(--color-muted)] mb-6">
          No mass production. No marketing-led shortcuts. Just plant-based formulations,
          made by hand, in quantities small enough that we know every batch.
        </p>
        <a href="/about/" class="btn btn-primary">Read more</a>
      </div>
      <div>
        <img
          src="/story/shampoo-stack.png"
          alt="MAADHURAM shampoo bottles styled with fresh herbs"
          class="rounded-xl shadow-[var(--shadow-soft)]"
        />
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container-page">
      <div class="bg-[var(--color-cream-dark)] border border-[var(--color-line)] rounded-2xl p-8 md:p-12 text-center">
        <div class="eyebrow mb-2">Place an order</div>
        <h2 class="text-2xl md:text-3xl mb-3">Order over WhatsApp.</h2>
        <p class="text-[var(--color-muted)] max-w-xl mx-auto mb-6">
          Pick what you'd like, message us with your address, and we'll confirm
          availability and shipping. Simple, personal, and the way most of our customers
          prefer to buy.
        </p>
        <a class="btn btn-whatsapp" href="https://wa.me/919652924824?text=Hi%20MAADHURAM%2C%20I%27d%20like%20to%20place%20an%20order." target="_blank" rel="noopener">
          Chat on WhatsApp
        </a>
      </div>
    </div>
  </section>

  <ChatWidget />
</BaseLayout>
